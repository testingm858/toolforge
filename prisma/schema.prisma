// Toolforge — Prisma Schema (reference only, NOT currently wired up)
//
// The app does not use Prisma at runtime. src/lib/db.ts implements the same
// tables directly on Node's built-in node:sqlite, and src/lib/prisma.ts is a
// hand-written shim that mimics the small slice of the Prisma client API the
// app calls, so existing `import prisma from "./prisma"` call sites keep
// working. There is no @prisma/client dependency and no generated client.
//
// Keep this file as the documented target shape for a future Postgres
// migration (swap db.ts/prisma.ts for `@prisma/client` + `provider =
// "postgresql"` + a real DATABASE_URL) — don't run `prisma db push` or
// `prisma generate` against it, they have nothing to connect to without that
// migration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  plan          String    @default("FREE")
  credits       Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  subscription Subscription?
  toolUsages   ToolUsage[]
  jobs         Job[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Billing ─────────────────────────────────────────────────────────────────

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  plan                 String    @default("FREE")
  status               String    @default("ACTIVE")
  creditsMonthly       Int       @default(0)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─── Tool Usage ──────────────────────────────────────────────────────────────

model ToolUsage {
  id           String   @id @default(cuid())
  userId       String?
  toolId       String
  category     String
  plan         String   @default("FREE")
  latencyMs    Int?
  success      Boolean  @default(true)
  creditsUsed  Int      @default(0)
  errorMessage String?
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([toolId, createdAt])
  @@map("tool_usages")
}

// ─── Async Jobs ───────────────────────────────────────────────────────────────

model Job {
  id          String    @id @default(cuid())
  userId      String?
  toolId      String
  status      String    @default("QUEUED")
  priority    Int       @default(3)
  resultUrl   String?
  errorMsg    String?
  progress    Int       @default(0)
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@map("jobs")
}

// ─── Tool Registry ────────────────────────────────────────────────────────────

model Tool {
  id          String   @id
  name        String
  slug        String   @unique
  category    String
  isPremium   Boolean  @default(false)
  isActive    Boolean  @default(true)
  description String?
  icon        String?
  apiProvider String?
  createdAt   DateTime @default(now())

  @@map("tools")
}
